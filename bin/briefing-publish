#!/usr/bin/env bash
# briefing-publish — commit docs/ and history.json, then push to origin/main.
#
# Always pushes to main, regardless of the current branch. GitHub Pages deploys
# from main only.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

DATE_STR="$(date -u +%Y-%m-%d)"

git add docs/ context/history.json bin/ src/ templates/ CLAUDE.md ROUTINE.md requirements.txt 2>/dev/null || true

if git diff --cached --quiet; then
  echo "[publish] nothing new to commit — proceeding to push"
else
  git commit -m "briefing: ${DATE_STR} daily intelligence update"
fi

# Always push to main, with retries for transient network failures
for i in 1 2 3 4; do
  if git push origin "HEAD:main"; then
    echo "[publish] pushed to main"
    exit 0
  fi
  # If rejected as non-fast-forward, rebase on main and retry
  echo "[publish] push failed (attempt $i) — rebasing on origin/main..."
  git fetch origin main
  git rebase origin/main || {
    echo "[publish] rebase conflict — manual resolution required" >&2
    exit 1
  }
  sleep $((2 ** i))
done

echo "[publish] ERROR: failed to push to main after 4 attempts" >&2
exit 1
