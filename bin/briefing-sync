#!/usr/bin/env bash
# briefing-sync — pull live state from origin/main into the working tree,
# regardless of what branch this session was created on.
#
# Syncs BOTH data files (history.json, docs/) AND code (src/, bin/, templates/,
# CLAUDE.md, ROUTINE.md, requirements.txt). This is the only way fixes pushed
# to main actually reach new sessions, since each session starts on a fresh
# feature branch that may pre-date those fixes.
#
# This is the FIRST step of every routine run.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "[sync] fetching origin/main..."
for i in 1 2 3 4; do
  if git fetch origin main 2>&1 | tail -3; then
    break
  fi
  echo "[sync] fetch failed (attempt $i), retrying in $((2 ** i))s..."
  sleep $((2 ** i))
done

# Sync data files
echo "[sync] restoring context/history.json and docs/ from origin/main..."
git checkout origin/main -- context/history.json 2>/dev/null || echo "[sync] no history.json on main yet — will init"
git checkout origin/main -- docs/ 2>/dev/null || echo "[sync] no docs/ on main yet"

# Sync code and config from main so fixes pushed to main reach every session
echo "[sync] restoring code and config from origin/main..."
git checkout origin/main -- src/ bin/ templates/ CLAUDE.md ROUTINE.md requirements.txt briefing_input.example.json 2>/dev/null || true

# Ensure required directories exist
mkdir -p context docs/adam docs/surali

# Initialise history.json if absent (first ever run)
if [ ! -f context/history.json ]; then
  echo "[sync] initialising empty history.json"
  python3 - <<'PY'
import json, pathlib
pathlib.Path("context/history.json").write_text(json.dumps({
    "adam":   {"last_updated": None, "covered_urls": [], "covered_topics": [], "daily": []},
    "surali": {"last_updated": None, "covered_urls": [], "covered_topics": [], "daily": []},
}, indent=2))
PY
fi

# Install Python deps quietly
echo "[sync] pip install -r requirements.txt"
pip install -r requirements.txt -q 2>&1 | tail -3 || true

echo "[sync] done — working tree ready"
