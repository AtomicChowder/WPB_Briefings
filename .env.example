# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI (https://newsapi.org - free tier supports 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# Google Cloud Platform
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCS_BUCKET_NAME=wpb-briefings-static
# Path to GCP service account key (omit in Cloud Run - uses default credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Notion Integration
NOTION_TOKEN=secret_your_notion_integration_token
# ID of the "WPB Weekly Intelligence Briefings" Notion database
NOTION_DATABASE_ID=your-notion-database-id-here

# App Security
# A random secret key to protect the /generate endpoint from unauthorized calls
SECRET_GENERATE_KEY=change-this-to-a-random-secret

# App Config
PORT=8080
ENVIRONMENT=development
# Minimum combined relevance score to include article in briefing (0-20)
MIN_ARTICLE_SCORE=6
